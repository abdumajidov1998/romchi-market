# Romchi Market backend — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In prod (Render) these are set via the dashboard, not from this file.

# Spring profile: dev (H2 file db) or prod (Postgres via DATABASE_URL)
SPRING_PROFILES_ACTIVE=dev

# Required in production
JWT_SECRET=change-me-to-random-32-char-string-or-longer
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Production datasource — driver-URL form is auto-translated to JDBC.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Server
PORT=3001
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

# Upload directory for multipart files (delivery, stanok-ads)
UPLOAD_DIR=./uploads

# Admin phones (comma-separated, must include + and country code)
# ADMIN_PHONES=+998901234567,+998991234567

# --- Eskiz SMS provider ----------------------------------------------------
# Empty = DEV mode (codes logged to backend stdout and echoed to the
# frontend's `devCode` field). Fill in to switch to live SMS.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# Override only if Eskiz changes its endpoints — defaults are fine.
# SMS_SEND_URL=https://notify.eskiz.uz/api/message/sms/send
# SMS_LOGIN_URL=https://notify.eskiz.uz/api/auth/login

# SMS rate limits (optional)
SMS_COOLDOWN_SEC=60
SMS_LIMIT_PHONE_HOUR=10
SMS_LIMIT_IP_HOUR=30
SMS_LIMIT_IP_DAY=100
