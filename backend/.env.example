# === Required in production ===
NODE_ENV=production
JWT_SECRET=change-me-to-random-32-char-string
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# === Database ===
# If set, uses Postgres. Otherwise falls back to SQLite at ./data/romchi.db
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATA_DIR=./data

# === SMS (Eskiz.uz) ===
# Required in production. In development, codes are logged to console.
# ESKIZ_EMAIL=
# ESKIZ_PASSWORD=

# === Server ===
PORT=3001
LOG_LEVEL=info

# === Admin ===
# Comma-separated list of phone numbers with admin privileges
# ADMIN_PHONES=+998901234567,+998991234567

# === SMS Limits (optional) ===
# SMS_COOLDOWN_SEC=60         # min seconds between resends to same phone
# SMS_LIMIT_PHONE_HOUR=10     # max SMS per phone per hour
# SMS_LIMIT_IP_HOUR=30        # max SMS per IP per hour
# SMS_LIMIT_IP_DAY=100        # max SMS per IP per 24h
